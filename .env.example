# NetOps Agent 环境变量模板（复制为 .env 后修改）
# 生产环境：务必更换所有密钥与默认密码

# ── LLM（必填）──
DEEPSEEK_API_KEY=
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1

# ── 安全（生产必改）──
SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_SECRET_KEY=change-me-same-as-secret-or-dedicated
JWT_ALGORITHM=HS256
ENFORCE_BFF_ORIGIN=true
BFF_REQUIRE_AUTH=true

# ── Django ──
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=netops_agent
POSTGRES_USER=netops
POSTGRES_PASSWORD=change-me-strong-password

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── Celery ──
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360

# ── MinIO ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_SECURE=false
MINIO_BUCKET_NAME=netops-files

# ── FastAPI / 应用 ──
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
USE_SUPERVISOR_V2=true

# Skill Catalog + 分级路由（Phase 2）
SKILL_CATALOG_ENABLED=true
SKILL_CATALOG_USE_TIERED_ROUTING=true
SKILL_CATALOG_SEMANTIC_MIN_SCORE=0.72
PRE_PROCESS_TOP_K=5
PRE_PROCESS_HARD_LIMIT=8
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
SKILL_RATE_LIMIT_ENABLED=true
SKILL_RATE_LIMIT_PER_USER=30
SKILL_RATE_LIMIT_PER_SKILL=200

# Skill 治理与归档（Phase 3）
SKILL_GOVERNANCE_ENABLED=true
PLATFORM_VERSION=1.0.0
SKILL_EXEC_ARCHIVE_ENABLED=true
SKILL_EXEC_ARCHIVE_AFTER_DAYS=90
SKILL_EXEC_ARCHIVE_BATCH_SIZE=500

# Redis Streams EventBus（Phase 1）
EVENT_BUS_ENABLED=true
EVENT_BUS_STREAM_MAXLEN=100000
EVENT_BUS_CONSUMER_BATCH_SIZE=20
EVENT_BUS_CONSUMER_BLOCK_MS=500
EVENT_BUS_POLL_IDLE_SEC=1.0
# true=EventBus 与 DB 通知双写（Consumer 未启动时仍能收到站内信）；false=仅 EventBus 投递
EVENT_BUS_DIRECT_NOTIFY_FALLBACK=true
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# ── 公网入口（下载链接 / ITSM 回调附件，无尾斜杠）──
# 生产示例：https://netops.example.com
# 留空则生成同源相对路径 /api/artifacts/download/...（浏览器与 React 同域时可用）
PUBLIC_APP_URL=

# ── BFF 代理（Django 容器内填 fastapi:8000）──
FASTAPI_BASE_URL=http://localhost:8000

# ── CORS（生产填实际前端域名，逗号分隔）──
# CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Langfuse（可选，未配置则自动降级）──
# LANGFUSE_HOST=http://localhost:3001
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ── ITSM ──
ITSM_WEBHOOK_SECRET=change-me-itsm-secret
# ITSM_CALLBACK_URL=

# ── 限流（可选）──
# BFF_RATE_LIMIT_CHAT=30
# BFF_RATE_LIMIT_DEFAULT=60
# BFF_RATE_LIMIT_IN_DEBUG=false

# ── Skill 路由 ──
# SEMANTIC_SKILL_MIN_CONFIDENCE=0.72
# CHAT_GRAPH_TIMEOUT=170
